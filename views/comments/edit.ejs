<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit</title>
</head>

<body>
    <h1>Edit</h1>
    <form method="post" action="/comments/<%= comment.id%>?_method=PATCH">
        <textarea name="comment" id="" cols="30" rows="15">
        <%= comment.comment %>
        </textarea>
        <button>Save</button>
    </form>
    <a href="/comments">Back to Comments</a>
</body>

</html>